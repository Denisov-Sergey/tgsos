# Получить на https://my.telegram.org
API_ID=12345
API_HASH=your_api_hash_here

# Путь к файлу сессии Telethon
# Локально: ./telethon_session
# Docker: /data/telethon_session (volume tgsos_data)
TELEGRAM_SESSION_PATH=./telethon_session

# URL БД
# Локально: sqlite в текущей папке
# Docker: sqlite в volume (обязательно для работы app и collector)
DATABASE_URL=sqlite+aiosqlite:///./tgsos.db

# Опционально: порт API (Docker)
# PORT=8000

# Опционально: лимит постов на канал при запуске collector (Docker)
# COLLECTOR_LIMIT=200
